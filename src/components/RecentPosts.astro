---
import type { Card } from '../types';

interface Props {
  cards: Card[];
  currentSlug?: string;
}

const { cards, currentSlug } = Astro.props;

const recentCards = cards
  .filter((card: Card) => card.slug !== currentSlug)
  .sort((a: Card, b: Card) => b.lastUpdateDate - a.lastUpdateDate)
  .slice(0, 10);
---

<div id="recent-posts" class="recent-posts-widget widget-item mb-4">
  <h3 class="widget-title">Recent Posts</h3>

  {recentCards.map((card: Card) => (
    <div class="post-item d-flex mb-3">
      <img
        src={card.imageUrl}
        alt={`${card.name} Image`}
        class="img-fluid flex-shrink-0"
        style="width:auto; height:70px; margin-right:10px;"
      />
      <div>
        <h4>
          <a href={card.localPageUrl}>
            Unlock Amazing Benefits with the <span class="text-success fw-bold">{card.name}</span>
          </a>
        </h4>
        <time datetime={new Date(card.lastUpdateDate).toISOString()}>
          {new Date(card.lastUpdateDate).toLocaleDateString('en-GB', {
            day: 'numeric',
            month: 'short',
            year: 'numeric'
          })}
        </time>
      </div>
    </div>
  ))}
</div>
