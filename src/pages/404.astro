---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
---

<BaseLayout
  title="Page Not Found - DuitFirst"
  description="The page you are looking for could not be found."
  bodyClass="error-page"
>
  <Fragment slot="head">
    <style>
      .error-card {
        max-width: 720px;
        margin: 0 auto;
        border: 1px solid rgba(25, 135, 84, 0.12);
        border-radius: 24px;
        padding: 2rem;
        background: #fff;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.05);
      }

      .error-code {
        font-size: clamp(3.5rem, 10vw, 6rem);
        line-height: 1;
        color: #198754;
        font-weight: 800;
      }

      .error-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      @media (max-width: 575.98px) {
        .error-card {
          padding: 1.5rem 1.25rem;
        }

        .error-actions a {
          width: 100%;
        }
      }
    </style>
  </Fragment>

  <main class="main">
    <PageTitle title="Page Not Found" />

    <section class="section">
      <div class="container">
        <div class="error-card text-center">
          <div class="error-code mb-3">404</div>
          <h2 class="mb-3 text-success">This page does not exist.</h2>
          <p class="mb-4">
            The link may be outdated, or the URL may have been entered incorrectly.
          </p>
          <div class="error-actions">
            <a href="/" class="btn btn-success">Back to Home</a>
            <a href="/support-us/" class="btn btn-outline-success">Support Us</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
