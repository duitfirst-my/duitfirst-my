---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageTitle from '../components/PageTitle.astro';
import allCards from '../data/all-card-data.json';
import type { Card } from '../types';

const cards = (allCards as Card[]).slice().sort((a, b) => b.lastUpdateDate - a.lastUpdateDate);
const recommendedCards = cards.filter((card) => card.recommended);
const banks = Array.from(
  new Map(
    cards.map((card) => [
      card.provider,
      {
        value: card.provider,
        label: card.original?.provider || card.provider
      }
    ])
  ).values()
).sort((a, b) => a.label.localeCompare(b.label));
const defaultBank = banks[0]?.value ?? '';
---

<BaseLayout
  title="DuitFirst - Simplifying Money, Savings, and Investments in Malaysia"
  description="DuitFirst helps Malaysians take charge of their finances with tips on budgeting, saving, and investments. Simplify your financial journey today!"
  keywords="personal finance Malaysia, money management tips, budgeting tips Malaysia, saving money ideas, investment tips Malaysia, smart money tips, ringgit savings tips, financial literacy Malaysia"
  canonical="https://www.duitfirst.my/"
  bodyClass="category-page"
>
  <Fragment slot="head">
    <style>
      .hide-scrollbar::-webkit-scrollbar {
        display: none;
      }

      .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      .scroll-indicator {
        animation: pulse 1.6s ease-in-out infinite;
        opacity: 0.7;
      }

      .section-spacer {
        margin-top: 3rem;
      }

      .bank-filter-select {
        max-width: 320px;
      }

      .recommendation-badge {
        display: inline-flex;
        align-items: center;
        align-self: flex-start;
        gap: 0.5rem;
        background: rgba(25, 135, 84, 0.1);
        color: #198754;
        border: 1px solid rgba(25, 135, 84, 0.2);
        border-radius: 999px;
        padding: 0.4rem 0.75rem;
        font-size: 0.82rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        letter-spacing: 0.01em;
        width: fit-content;
      }

      @media (max-width: 767.98px) {
        .bank-filter-select {
          max-width: 100%;
          width: 100%;
        }
      }

      @keyframes pulse {
        0% {
          opacity: 0.4;
          transform: translateX(0);
        }
        50% {
          opacity: 1;
          transform: translateX(6px);
        }
        100% {
          opacity: 0.4;
          transform: translateX(0);
        }
      }
    </style>
  </Fragment>

  <main class="main">
    <PageTitle title="Home" breadcrumbs={['Home']} positionRelative={true} />

    <div class="container">
      <div class="row">
        <div class="col-lg-8">
          <section id="blog-posts" class="blog-posts section">
            <div class="container hide-scrollbar" style="overflow-y:scroll; overflow-x:hidden;">
              <div class="row gy-4">
                <div id="most-recent-posts" class="col-12">
                  <h3 class="text-center">Most Recent Posts</h3>
                  <hr />
                  <p class="text-end scroll-indicator">
                    Scroll For More <i class="bi bi-chevron-double-right" style="font-size: 1rem;"></i>
                  </p>
                </div>

                <div class="row flex-nowrap overflow-x-scroll hide-scrollbar pb-3" id="recent-posts-container">
                  {cards.map((card) => (
                    <div class="col-lg-6 flex-shrink-0">
                      <article class="position-relative h-100">
                        <div class="post-img position-relative overflow-hidden">
                          <img src={card.imageUrl} class="img-fluid" alt={card.name} />
                          <span class="post-date">
                            {new Date(card.lastUpdateDate).toLocaleDateString('en-GB', {
                              day: 'numeric',
                              month: 'short',
                              year: 'numeric'
                            })}
                          </span>
                        </div>
                        <div class="post-content d-flex flex-column">
                          {card.recommended && (
                            <p class="recommendation-badge">
                              <i class="bi bi-hand-thumbs-up-fill" aria-hidden="true"></i>
                              Highly Recommended
                            </p>
                          )}
                          <h3 class="post-title">
                            Unlock Amazing Benefits with the <span class="fw-bold text-success">{card.name}</span>!
                          </h3>
                          {card.highlights && card.highlights.length > 0 && (
                            <ul>
                              {card.highlights.map((item) => <li>{item}</li>)}
                            </ul>
                          )}
                          <hr />
                          <a href={card.localPageUrl} class="readmore stretched-link">
                            <span>Learn More</span><i class="bi bi-arrow-right"></i>
                          </a>
                        </div>
                      </article>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </section>
        </div>

        <div class="col-lg-4 sidebar">
          <div class="widgets-container">
            <section id="about" class="about section pt-0">
              <div class="container">
                <div class="row">
                  <div class="col-12 content" data-aos="fade-left" data-aos-delay="100">
                    <h3>Personal Finance, Simplified</h3>

                    <p class="fs-4">
                      <span class="text-success fw-bold">DuitFirst</span> helps Malaysians make quick & confident money decisions, without the noise.
                    </p>

                    <ul>
                      <li><i class="bi bi-check-circle"></i> <span>Clear breakdowns of cards, savings, and money tools.</span></li>
                      <li><i class="bi bi-check-circle"></i> <span>Only the details that actually matter.</span></li>
                      <li><i class="bi bi-check-circle"></i> <span>Perfect for quick checks and refreshing what you already know.</span></li>
                    </ul>

                    <p class="fs-4">
                      When it comes to managing money, start with what matters — <b class="text-success">Du it First</b>.<br />
                      Simple enough to remember, practical enough to act on.
                    </p>
                  </div>
                </div>
              </div>
            </section>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-12">
          <section class="blog-posts section pt-0">
            <div class="container hide-scrollbar" style="overflow-y:scroll; overflow-x:hidden;">
              <div class="row gy-4">
                <div id="browse-by-bank" class="col-12 section-spacer">
                  <div class="d-md-flex justify-content-between align-items-center gap-3">
                    <div>
                      <h3 class="text-center text-md-start mb-2 mb-md-0">Browse by Bank</h3>
                    </div>
                    <div class="bank-filter-select ms-md-auto">
                      <label class="form-label visually-hidden" for="bank-filter">Select Bank</label>
                      <select id="bank-filter" class="form-select">
                        {banks.map((bank) => (
                          <option value={bank.value} selected={bank.value === defaultBank}>
                            {bank.label}
                          </option>
                        ))}
                      </select>
                    </div>
                  </div>
                  <hr />
                  <p class="text-end scroll-indicator">
                    Scroll For More <i class="bi bi-chevron-double-right" style="font-size: 1rem;"></i>
                  </p>
                </div>

                <div class="row flex-nowrap overflow-x-scroll hide-scrollbar pb-3" id="bank-posts-container">
                  {cards.map((card) => (
                    <div
                      class="col-lg-4 col-md-6 flex-shrink-0 bank-card"
                      data-provider={card.provider}
                      style={card.provider === defaultBank ? '' : 'display:none;'}
                    >
                      <article class="position-relative h-100">
                        <div class="post-img position-relative overflow-hidden">
                          <img src={card.imageUrl} class="img-fluid" alt={card.name} />
                          <span class="post-date">
                            {new Date(card.lastUpdateDate).toLocaleDateString('en-GB', {
                              day: 'numeric',
                              month: 'short',
                              year: 'numeric'
                            })}
                          </span>
                        </div>
                        <div class="post-content d-flex flex-column">
                          {card.recommended && (
                            <p class="recommendation-badge">
                              <i class="bi bi-hand-thumbs-up-fill" aria-hidden="true"></i>
                              Highly Recommended
                            </p>
                          )}
                          <h3 class="post-title">
                            Unlock Amazing Benefits with the <span class="fw-bold text-success">{card.name}</span>!
                          </h3>
                          {card.highlights && card.highlights.length > 0 && (
                            <ul>
                              {card.highlights.map((item) => <li>{item}</li>)}
                            </ul>
                          )}
                          <hr />
                          <a href={card.localPageUrl} class="readmore stretched-link">
                            <span>Learn More</span><i class="bi bi-arrow-right"></i>
                          </a>
                        </div>
                      </article>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>

      {recommendedCards.length > 0 && (
        <div class="row">
          <div class="col-12">
            <section class="blog-posts section pt-0">
              <div class="container hide-scrollbar" style="overflow-y:scroll; overflow-x:hidden;">
                <div class="row gy-4">
                  <div id="highly-recommended" class="col-12 section-spacer">
                    <h3 class="text-center">Highly Recommended</h3>
                    <hr />
                    <p class="text-end scroll-indicator">
                      Scroll For More <i class="bi bi-chevron-double-right" style="font-size: 1rem;"></i>
                    </p>
                  </div>

                  <div class="row flex-nowrap overflow-x-scroll hide-scrollbar pb-3">
                    {recommendedCards.map((card) => (
                      <div class="col-lg-4 col-md-6 flex-shrink-0">
                        <article class="position-relative h-100">
                          <div class="post-img position-relative overflow-hidden">
                            <img src={card.imageUrl} class="img-fluid" alt={card.name} />
                            <span class="post-date">
                              {new Date(card.lastUpdateDate).toLocaleDateString('en-GB', {
                                day: 'numeric',
                                month: 'short',
                                year: 'numeric'
                              })}
                            </span>
                          </div>
                          <div class="post-content d-flex flex-column">
                            <p class="recommendation-badge mb-2">
                              <i class="bi bi-hand-thumbs-up-fill" aria-hidden="true"></i>
                              Highly Recommended
                            </p>
                            <h3 class="post-title">
                              Unlock Amazing Benefits with the <span class="fw-bold text-success">{card.name}</span>!
                            </h3>
                            {card.highlights && card.highlights.length > 0 && (
                              <ul>
                                {card.highlights.map((item) => <li>{item}</li>)}
                              </ul>
                            )}
                            <hr />
                            <a href={card.localPageUrl} class="readmore stretched-link">
                              <span>Learn More</span><i class="bi bi-arrow-right"></i>
                            </a>
                          </div>
                        </article>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </section>
          </div>
        </div>
      )}
    </div>
  </main>

  <script slot="scripts" is:inline>
    const bankFilter = document.getElementById('bank-filter');
    const bankCards = Array.from(document.querySelectorAll('.bank-card'));
    const bankPostsContainer = document.getElementById('bank-posts-container');

    function updateBankCards() {
      const selectedBank = bankFilter?.value;

      bankCards.forEach((card) => {
        card.style.display = card.dataset.provider === selectedBank ? '' : 'none';
      });

      bankPostsContainer?.scrollTo({
        left: 0,
        behavior: 'auto'
      });
    }

    bankFilter?.addEventListener('change', updateBankCards);
    updateBankCards();
  </script>
</BaseLayout>
